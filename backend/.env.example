# ── LLM ──────────────────────────────────────────────
# Get from https://aistudio.google.com/
# AI Studio billing is linked to your GCP account — no Vertex AI needed.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Scraping ─────────────────────────────────────────
# Optional — if empty, scraper falls back to Playwright (free, no key needed).
# Free tier at firecrawl.dev gives 500 one-time credits — fine for development.
# Without Firecrawl: Playwright handles JS rendering + html2text converts to markdown.
FIRECRAWL_API_KEY=

# ── GCP (optional — for production artifact storage) ──
# Leave both empty during development — artifacts are stored in local /tmp.
# For production on Cloud Run, set these to store HTML + screenshots in GCS.
# GOOGLE_CLOUD_PROJECT accepts either the project name or numeric project ID.
GOOGLE_CLOUD_PROJECT=
GCS_BUCKET=

# ── CORS ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── LangSmith observability (optional) ───────────────
# LangSmith is an optional tracing dashboard for LangGraph pipelines.
# When enabled, every pipeline run is logged with per-node timing,
# inputs/outputs, and costs. Useful for debugging agent behavior.
#
# To enable:
#   1. Create account at https://smith.langchain.com
#   2. Set LANGCHAIN_TRACING_V2=true
#   3. Paste your API key below
#
# Leave false during development — no key needed, no data sent.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=retrofit-cro-agent
