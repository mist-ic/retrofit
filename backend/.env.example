# ── LLM ──────────────────────────────────────────────
# Get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Scraping ─────────────────────────────────────────
# Optional — if empty, scraper falls back to Playwright (free, no key needed).
# Free tier at firecrawl.dev gives 500 one-time credits — fine for development.
# Without Firecrawl: Playwright handles JS rendering + html2text converts to markdown.
FIRECRAWL_API_KEY=

# ── GCP (optional — for production artifact storage) ──
# Leave empty to use local /tmp storage during development
GOOGLE_CLOUD_PROJECT=
GCS_BUCKET=

# ── CORS ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Observability (optional) ──────────────────────────
# Get from https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=retrofit-cro-agent
